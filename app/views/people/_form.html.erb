<%= form_with(model: person, class: "contents") do |form| %>
  <% if person.errors.any? %>
    <div id="error_explanation" class="mb-6 rounded-md border border-danger/25 bg-danger-soft px-4 py-3 text-sm text-danger">
      <h2 class="font-medium"><%= pluralize(person.errors.count, "error") %> prohibited this person from being saved:</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5">
        <% person.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-5">
    <%= form.label :first_name, class: "field-label" %>
    <%= form.text_field :first_name, class: ["field-input", { "field-input-error": person.errors[:first_name].any? }] %>
  </div>

  <div class="mb-5">
    <%= form.label :last_name, class: "field-label" %>
    <%= form.text_field :last_name, class: ["field-input", { "field-input-error": person.errors[:last_name].any? }] %>
  </div>

  <div class="mb-5">
    <%= form.label :gender, class: "field-label" %>
    <%= form.select :gender,
                   [["Male", "male"], ["Female", "female"]],
                   { prompt: "Select gender" },
                   class: ["field-input", { "field-input-error": person.errors[:gender].any? }] %>
  </div>

  <div class="mb-5">
    <%= form.label :father_id, "Father", class: "field-label" %>
    <%= form.collection_select :father_id,
                             Person.where(gender: "male"),
                             :id,
                             :display_name,
                             { include_blank: "Not specified" },
                             { class: ["field-input", { "field-input-error": person.errors[:father_id].any? }] } %>
  </div>

  <div class="mb-8">
    <%= form.label :mother_id, "Mother", class: "field-label" %>
    <%= form.collection_select :mother_id,
                             Person.where(gender: "female"),
                             :id,
                             :display_name,
                             { include_blank: "Not specified" },
                             { class: ["field-input", { "field-input-error": person.errors[:mother_id].any? }] } %>
  </div>

  <div>
    <%= form.submit class: "btn-primary cursor-pointer" %>
  </div>
<% end %>
