<% content_for :title, @person.display_name %>

<div class="mx-auto max-w-6xl">
  <% if notice.present? %>
    <p class="notice" id="notice"><%= notice %></p>
  <% end %>

  <div class="mb-10 animate-rise">
    <p class="text-sm font-medium uppercase tracking-wide text-ink-muted">Person</p>
    <h1 class="mt-2 font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl">
      <%= sanitize @person.display_name %>
    </h1>
    <p class="mt-3 text-sm capitalize text-ink-muted"><%= @person.gender %></p>
  </div>

  <%= render @person %>

  <div class="mt-12 flex flex-wrap items-center gap-3 border-t border-ink/10 pt-8">
    <%= link_to "Edit", edit_person_path(@person), class: "btn-primary" %>
    <%= link_to "Back to people", people_path, class: "btn-secondary" %>
    <%= button_to "Delete", @person,
        method: :delete,
        class: "btn-danger cursor-pointer",
        data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
