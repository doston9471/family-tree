<div id="<%= dom_id person %>" class="space-y-12 animate-rise-delay-1">
  <section>
    <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
      <div>
        <h2 class="font-display text-2xl font-semibold text-ink">Ancestors</h2>
        <p class="mt-1 text-sm text-ink-muted">Lineage looking upward — parents branch above each generation.</p>
      </div>
    </div>

    <div class="ancestors-panel">
      <% if @ancestors_data[:father].present? || @ancestors_data[:mother].present? %>
        <%= render "ancestor_branch", node: @ancestors_data, focus: true %>
      <% else %>
        <p class="empty-lineage">No ancestors recorded yet. Add a father or mother to grow this branch.</p>
      <% end %>
    </div>
  </section>

  <section>
    <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
      <div>
        <h2 class="font-display text-2xl font-semibold text-ink">Descendants</h2>
        <p class="mt-1 text-sm text-ink-muted">Lineage looking downward — children branch below each generation.</p>
      </div>
    </div>

    <div class="descendants-panel">
      <% if @descendants_data[:spouses].present? %>
        <%= render "descendant_tree", node: @descendants_data, root: true %>
      <% else %>
        <p class="empty-lineage">No descendants yet. Children linked to this person will appear here.</p>
      <% end %>
    </div>
  </section>
</div>
