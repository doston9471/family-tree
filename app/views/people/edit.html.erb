<% content_for :title, "Edit #{@person.display_name}" %>

<div class="mx-auto max-w-xl">
  <div class="mb-8 animate-rise">
    <p class="text-sm font-medium uppercase tracking-wide text-ink-muted">Edit</p>
    <h1 class="mt-2 font-display text-4xl font-semibold tracking-tight text-ink">
      <%= sanitize @person.display_name %>
    </h1>
    <p class="mt-3 text-ink-muted">Update details or parent connections for this person.</p>
  </div>

  <div class="animate-rise-delay-1 rounded-lg border border-ink/10 bg-paper/80 p-6 sm:p-8">
    <%= render "form", person: @person %>
  </div>

  <div class="mt-6 flex flex-wrap gap-2">
    <%= link_to "Show this person", @person, class: "btn-ghost" %>
    <%= link_to "Back to people", people_path, class: "btn-ghost" %>
  </div>
</div>
