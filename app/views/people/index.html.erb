<% content_for :title, "Ancestry Tree" %>

<% if notice.present? %>
  <p class="notice" id="notice"><%= notice %></p>
<% end %>

<section class="relative -mx-5 mb-16 overflow-hidden px-5 pb-4 pt-6 md:mb-20 md:pt-10">
  <div class="relative z-10 max-w-2xl">
    <p class="animate-rise font-display text-5xl font-semibold tracking-tight text-ink sm:text-6xl md:text-7xl">
      Ancestry Tree
    </p>
    <h1 class="animate-rise-delay-1 mt-5 font-display text-2xl font-medium leading-snug text-ink-muted sm:text-3xl">
      Map the people who came before — and those who follow.
    </h1>
    <p class="animate-rise-delay-2 mt-4 max-w-lg text-base leading-relaxed text-ink-muted sm:text-lg">
      Build a living record of your family: add relatives, connect parents, and explore ancestors and descendants in one place.
    </p>
    <div class="animate-rise-delay-3 mt-8 flex flex-wrap items-center gap-3">
      <%= link_to "Add a person", new_person_path, class: "btn-primary" %>
      <a href="#people" class="btn-secondary">Browse people</a>
    </div>
  </div>
</section>

<section id="people" class="scroll-mt-24">
  <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
    <div>
      <h2 class="font-display text-3xl font-semibold tracking-tight text-ink">People</h2>
      <p class="mt-1 text-sm text-ink-muted">
        <%= pluralize(@people.size, "person") %> in your tree
      </p>
    </div>
    <%= link_to "New person", new_person_path, class: "btn-secondary" %>
  </div>

  <% if @people.any? %>
    <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
      <% @people.each_with_index do |person, index| %>
        <article class="person-card stagger-item" style="animation-delay: <%= [index * 0.05, 0.4].min %>s">
          <div class="mb-4 flex items-start justify-between gap-3">
            <h3 class="font-display text-xl font-semibold leading-snug text-ink">
              <%= link_to sanitize(person.display_name), person, class: "hover:text-olive" %>
            </h3>
            <span class="shrink-0 text-xs font-medium uppercase tracking-wide text-ink-muted">
              <%= person.gender %>
            </span>
          </div>

          <div class="mb-5 flex-1 space-y-2 text-sm text-ink-muted">
            <p>
              <span class="font-medium text-ink/70">Father</span>
              <% if person.father %>
                <span class="ml-1"><%= sanitize person.father.display_name %></span>
              <% else %>
                <span class="ml-1 italic opacity-60">Not specified</span>
              <% end %>
            </p>
            <p>
              <span class="font-medium text-ink/70">Mother</span>
              <% if person.mother %>
                <span class="ml-1"><%= sanitize person.mother.display_name %></span>
              <% else %>
                <span class="ml-1 italic opacity-60">Not specified</span>
              <% end %>
            </p>
          </div>

          <div class="flex flex-wrap items-center gap-1 border-t border-ink/10 pt-4">
            <%= link_to "Show", person, class: "btn-primary !px-3 !py-1.5 !text-xs" %>
            <%= link_to "Edit", edit_person_path(person), class: "btn-ghost" %>
            <%= button_to "Delete", person,
                method: :delete,
                class: "btn-danger-ghost cursor-pointer",
                data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-lg border border-dashed border-ink/20 bg-paper/60 px-6 py-16 text-center">
      <p class="font-display text-2xl font-medium text-ink">Your tree is empty</p>
      <p class="mx-auto mt-2 max-w-md text-ink-muted">
        Add the first person to begin tracing lineage across generations.
      </p>
      <%= link_to "Add a person", new_person_path, class: "btn-primary mt-6" %>
    </div>
  <% end %>
</section>
