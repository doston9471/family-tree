<% content_for :title, "New person" %>

<div class="mx-auto max-w-xl">
  <div class="mb-8 animate-rise">
    <p class="text-sm font-medium uppercase tracking-wide text-ink-muted">Add to the tree</p>
    <h1 class="mt-2 font-display text-4xl font-semibold tracking-tight text-ink">New person</h1>
    <p class="mt-3 text-ink-muted">Record a relative and link them to their parents.</p>
  </div>

  <div class="animate-rise-delay-1 rounded-lg border border-ink/10 bg-paper/80 p-6 sm:p-8">
    <%= render "form", person: @person %>
  </div>

  <div class="mt-6">
    <%= link_to "Back to people", people_path, class: "btn-ghost" %>
  </div>
</div>
