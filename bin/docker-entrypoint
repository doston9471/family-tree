#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
  LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
  export LD_PRELOAD
fi

# With bind-mounted source, keep gems in sync with the Gemfile.
if [ -f Gemfile ]; then
  bundle check >/dev/null 2>&1 || bundle install
fi

# Prepare the DB when starting the app server (dev, rails server, or thruster).
if [[ " $* " == *" server "* ]] || [[ "$1" == "./bin/thrust" ]] || [[ "$1" == "bin/dev" ]] || [[ "$1" == "./bin/dev" ]]; then
  ./bin/rails db:prepare

  if [[ "${SEED}" == "1" || "${SEED}" == "true" ]]; then
    ./bin/rails db:seed
  elif [[ "$(./bin/rails runner 'print Person.count')" == "0" ]]; then
    echo "No people found — loading seeds..."
    ./bin/rails db:seed
  fi

  ./bin/rails tailwindcss:build
fi

exec "${@}"
